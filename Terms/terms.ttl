pesc:Summary a rdfs:Class ;
    rdfs:label "Summary" ;
    dct:identifier "https://pesc.org/terms/Summary" ;
    rdfs:isDefinedBy pesc: .

pesc:academicHonors a rdf:Property ;
    rdfs:label "Academic Honors" ;
    rdfs:isDefinedBy pesc: ;
    skos:notation "academicHonors" ;
    sdo:domainIncludes pesc:AcademicSummary,
        pesc:AwardSummary,
        pesc:ProgramSummary,
        pesc:SessionSummary ;
    sdo:rangeIncludes pesc:AcademicHonors .

pesc:academicSummaryLevel a rdf:Property ;
    rdfs:label "Academic Summary Level" ;
    rdfs:isDefinedBy pesc: ;
    skos:notation "academicSummaryLevel" ;
    sdo:domainIncludes pesc:AcademicSummary,
        pesc:AwardSummary,
        pesc:ProgramSummary,
        pesc:SessionSummary ;
    sdo:rangeIncludes skos:Concept .

pesc:academicSummaryType a rdf:Property ;
