pesc:Grade a rdfs:Class ;
    rdfs:label "Grade" ;
    dct:identifier "https://pesc.org/terms/Grade" ;
    rdfs:isDefinedBy pesc: .

pesc:Licensure a rdfs:Class ;
    rdfs:label "Licensure" ;
    dct:identifier "https://pesc.org/terms/Licensure" ;
