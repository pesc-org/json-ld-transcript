@prefix ceds: <http://ceds.ed.gov/terms#> .
@prefix dct: <http://purl.org/dc/terms/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix pesc: <https://pesc.org/terms/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix sdo: <https://schema.org/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix vann: <http://purl.org/vocab/vann/> .

pesc: a owl:Ontology ;
    dct:description "RDF declaration of properties and classes in the pesc: namespace." ;
    dct:title "Pesc RDF Terms" ;
    vann:preferredNamespacePrefix "pesc" .

pesc:AcademicDegreeRequirement a rdfs:Class ;
    rdfs:label "Academic Degree Requirement" ;
    dct:identifier "https://pesc.org/terms/AcademicDegreeRequirement" ;
    rdfs:isDefinedBy pesc: .

pesc:AcademicHonors a rdfs:Class ;
    rdfs:label "Academic Honors" ;
    dct:identifier "https://pesc.org/terms/AcademicHonors" ;
    rdfs:isDefinedBy pesc: .

pesc:AcademicSummary a rdfs:Class ;
    rdfs:label "Academic Summary" ;
    dct:identifier "https://pesc.org/terms/AcademicSummary" ;
    rdfs:isDefinedBy pesc: .

