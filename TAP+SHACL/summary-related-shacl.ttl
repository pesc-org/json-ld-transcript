# SHACL generated by python AP to shacl converter
@base <http://example.org/> .
@prefix ceds: <http://ceds.ed.gov/terms#> .
@prefix ceterms: <https://purl.org/ctdl/terms/> .
@prefix elm: <http://data.europa.eu/snb/model/elm/> .
@prefix ex: <http://example.org/> .
@prefix pesc: <https://pesc.org/terms/> .
@prefix pescAcademicSummaryTypes: <https://pesc.org/vocabs/AcademicSummaryTypes#> .
@prefix pescCreditLevels: <https://pesc.org/vocabs/CreditLevels#> .
@prefix pescDelinquencyCodes: <https://pesc.org/vocabs/DelinquencyCodes#> .
@prefix pescHonorsLevels: <https://pesc.org/vocabs/HonorsLevels#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix sh: <http://www.w3.org/ns/shacl#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<AcademicDegreeRequirementShape> a sh:NodeShape ;
    rdfs:label "Academic Degree Requirement"@en ;
    sh:closed false ;
    sh:targetClass pesc:AcademicDegreeRequirement .

<AcademicSummaryShape> a sh:NodeShape ;
    rdfs:label "Academic Summary"@en ;
    sh:closed false ;
    sh:property <academicsummaryshapeAcademicHonors>,
        <academicsummaryshapeAcademicSummaryLevel>,
        <academicsummaryshapeAcademicSummaryType>,
        <academicsummaryshapeAdditionalNote>,
        <academicsummaryshapeDelinquencies>,
        <academicsummaryshapeEntryDate>,
        <academicsummaryshapeExitDate>,
        <academicsummaryshapeGPASummary>,
        <academicsummaryshapeIsSummaryForProgram>,
        <academicsummaryshapeSource>,
        <academicsummaryshapeType> ;
    sh:targetClass pesc:AcademicSummary .

<AccreditationShape> a sh:NodeShape ;
    rdfs:label "Accreditation"@en ;
    sh:closed false ;
    sh:targetClass ceds:C200240 .

<AdditionalStudentAchievementShape> a sh:NodeShape ;
    rdfs:label "Additional Student Achievement"@en ;
    sh:closed false ;
    sh:targetClass pesc:AdditionalStudentAchievement .

<AgencyIdentifierShape> a sh:NodeShape ;
    rdfs:label "Agency Identifier"@en ;
    sh:closed false ;
    sh:targetClass pesc:AgencyIdentifier .

<AwardSummaryShape> a sh:NodeShape ;
    rdfs:label "Award Summary"@en ;
    sh:closed false ;
    sh:property <awardsummaryshapeAcademicHonors>,
        <awardsummaryshapeAcademicSummaryLevel>,
        <awardsummaryshapeAcademicSummaryType>,
        <awardsummaryshapeAdditionalNote>,
        <awardsummaryshapeGPASummary>,
        <awardsummaryshapeIsSummaryForAward>,
        <awardsummaryshapeIsSummaryForProgram>,
        <awardsummaryshapeSource>,
        <awardsummaryshapeType> ;
    sh:targetClass pesc:AwardSummary .

<CollegeTranscriptShape> a sh:NodeShape ;
    rdfs:label "College Transcript"@en ;
    sh:closed false ;
    sh:targetClass pesc:CollegeTranscript .

<ConceptShape> a sh:NodeShape ;
    rdfs:label "SKOS Concept"@en ;
    sh:closed false ;
    sh:targetClass skos:Concept .

<ContactShape> a sh:NodeShape ;
    rdfs:label "Contact"@en ;
    sh:closed false ;
    sh:targetClass ceterms:ContactPoint .

<CourseAchievementShape> a sh:NodeShape ;
    rdfs:label "Course Achievement"@en ;
    sh:closed false ;
    sh:targetClass ceds:C200346 .

<CourseShape> a sh:NodeShape ;
    rdfs:label "Post Secondary Course"@en ;
    sh:closed false ;
    sh:targetClass ceds:C200328 .

<CourseSupplementalGradeShape> a sh:NodeShape ;
    rdfs:label "Course Supplemental Grade"@en ;
    sh:closed false ;
    sh:targetClass pesc:CourseSupplementalGrade .

<GradeShape> a sh:NodeShape ;
    rdfs:label "Grade"@en ;
    sh:closed false ;
    sh:targetClass pesc:Grade .

<LanguageShape> a sh:NodeShape ;
    rdfs:label "Person Language"@en ;
    sh:closed false ;
    sh:targetClass ceds:C200293 .

<LicensureAchievementShape> a sh:NodeShape ;
    rdfs:label "Licensure Achievement"@en ;
    sh:closed false ;
    sh:targetClass pesc:LicensureAchievement .

<LicensureShape> a sh:NodeShape ;
    rdfs:label "Licensure"@en ;
    sh:closed false ;
    sh:targetClass pesc:Licensure .

<OrganizationIdentifierShape> a sh:NodeShape ;
    rdfs:label "Organization Identifier"@en ;
    sh:closed false ;
    sh:severity sh:Info ;
    sh:targetClass ceds:C200252 .

<PersonIdentifierShape> a sh:NodeShape ;
    rdfs:label "Person Identifier"@en ;
    sh:closed false ;
    sh:targetClass ceds:C200291 .

<PersonNameShape> a sh:NodeShape ;
    rdfs:label "Name"@en ;
    sh:closed false ;
    sh:targetClass ceds:C200377 .

<PhoneShape> a sh:NodeShape ;
    rdfs:label "Phone"@en ;
    sh:closed false ;
    sh:targetClass pesc:Phone .

<PostalAddressShape> a sh:NodeShape ;
    rdfs:label "Postal Address"@en ;
    sh:closed false ;
    sh:targetClass ceterms:PostalAddress .

<PostsecondarySectionLocationShape> a sh:NodeShape ;
    rdfs:label "Postsecondary Section Location"@en ;
    sh:closed false ;
    sh:targetClass ceds:C200333 .

<PostsecondarySectionShape> a sh:NodeShape ;
    rdfs:label "Postsecondary Location"@en ;
    sh:closed false ;
    sh:targetClass ceds:C200332 .

<ProgramSummaryShape> a sh:NodeShape ;
    rdfs:label "Program Summary"@en ;
    sh:closed false ;
    sh:property <programsummaryshapeAcademicHonors>,
        <programsummaryshapeAcademicSummaryLevel>,
        <programsummaryshapeAcademicSummaryType>,
        <programsummaryshapeAdditionalNote>,
        <programsummaryshapeDelinquencies>,
        <programsummaryshapeExitDate>,
        <programsummaryshapeGPASummary>,
        <programsummaryshapeIsSummaryForProgram>,
        <programsummaryshapeSource>,
        <programsummaryshapeType> ;
    sh:targetClass pesc:ProgramSummary .

<RAPShape> a sh:NodeShape ;
    rdfs:label "Requirement, Attribute or Proficiency"@en ;
    sh:closed false ;
    sh:targetClass ceds:C200065 .

<ResidencyShape> a sh:NodeShape ;
    rdfs:label "Residency"@en ;
    sh:closed false ;
    sh:targetClass pesc:Residency .

<SessionSummaryShape> a sh:NodeShape ;
    rdfs:label "Session Summary"@en ;
    sh:closed false ;
    sh:property <sessionsummaryshapeAcademicHonors>,
        <sessionsummaryshapeAcademicSummaryLevel>,
        <sessionsummaryshapeAcademicSummaryType>,
        <sessionsummaryshapeAdditionalNote>,
        <sessionsummaryshapeDelinquencies>,
        <sessionsummaryshapeEntryDate>,
        <sessionsummaryshapeExitDate>,
        <sessionsummaryshapeGPASummary>,
        <sessionsummaryshapeIsSummaryForProgram>,
        <sessionsummaryshapeIsSummaryForSession>,
        <sessionsummaryshapeSource>,
        <sessionsummaryshapeType> ;
    sh:targetClass pesc:SessionSummary .

<StudentShape> a sh:NodeShape ;
    rdfs:label "Student"@en ;
    sh:closed false ;
    sh:property <studentshapeHasSummary> ;
    sh:targetClass ceds:C200275 .

<SubtestShape> a sh:NodeShape ;
    rdfs:label "Subtest"@en ;
    sh:closed false ;
    sh:targetClass ceds:C200051 .

<SummaryShape> a sh:NodeShape ;
    rdfs:label "Summary"@en ;
    sh:closed false ;
    sh:targetClass pesc:Summary .

<TestScoreShape> a sh:NodeShape ;
    rdfs:label "Test Scores"@en ;
    sh:closed false ;
    sh:targetClass ceds:C200047 .

<TestShape> a sh:NodeShape ;
    rdfs:label "Test"@en ;
    sh:closed false ;
    sh:targetClass ceds:C200010 .

<AcademicAwardShape> a sh:NodeShape ;
    rdfs:label "Postsecondary Student Academic Award"@en ;
    sh:closed false ;
    sh:targetClass ceds:C200335 .

<AcademicSessionShape> a sh:NodeShape ;
    rdfs:label "Academic Session"@en ;
    sh:closed false ;
    sh:targetClass ceds:C200245 .

<academichonorsshapeHonorsLevel> a sh:PropertyShape ;
    sh:in ( pescHonorsLevels:FirstHighest pescHonorsLevels:SecondHighest pescHonorsLevels:ThirdHighest ) ;
    sh:maxCount 1 ;
    sh:name "Honors Level"@en-US ;
    sh:nodeKind sh:IRI ;
    sh:path pesc:honorsLevel .

<academichonorsshapeHonorsTitle> a sh:PropertyShape ;
    sh:datatype xsd:string ;
    sh:maxCount 1 ;
    sh:maxLength 30 ;
    sh:name "Honors Title"@en-US ;
    sh:nodeKind sh:Literal ;
    sh:path pesc:honorsTitle .

<academichonorsshapeType> a sh:PropertyShape ;
    sh:hasValue pesc:AcademicHonors ;
    sh:minCount 1 ;
    sh:name "Type"@en-US ;
    sh:nodeKind sh:IRI ;
    sh:path rdf:type .

<academicsummaryshapeAcademicHonors> a sh:PropertyShape ;
    sh:class pesc:AcademicHonors ;
    sh:maxCount 1 ;
    sh:name "Academic Honors"@en-US ;
    sh:node <AcademicHonorsShape> ;
    sh:nodeKind sh:BlankNode ;
    sh:path pesc:academicHonors .

<academicsummaryshapeAcademicSummaryLevel> a sh:PropertyShape ;
    sh:in ( pescCreditLevels:Dual pescCreditLevels:DualGraduate pescCreditLevels:Undergraduate pescCreditLevels:Grade13 pescCreditLevels:Ungraded pescCreditLevels:DualHighSchoolCollege pescCreditLevels:Graduate pescCreditLevels:GraduateProfessional pescCreditLevels:LowerDivision pescCreditLevels:Professional pescCreditLevels:Secondary pescCreditLevels:TechnicalPreparatory pescCreditLevels:UpperDivision pescCreditLevels:Vocational ) ;
    sh:maxCount 1 ;
    sh:name "Academic Summary Level"@en-US ;
    sh:nodeKind sh:IRI ;
    sh:path pesc:academicSummaryLevel .

<academicsummaryshapeAcademicSummaryType> a sh:PropertyShape ;
    sh:in ( pescAcademicSummaryTypes:All pescAcademicSummaryTypes:SenderOnly pescAcademicSummaryTypes:TransferOnly pescAcademicSummaryTypes:AllNotRepeated pescAcademicSummaryTypes:SenderNotRepeated pescAcademicSummaryTypes:TransferNotRepeated pescAcademicSummaryTypes:AcademicRenewal pescAcademicSummaryTypes:CarryoverCredit pescAcademicSummaryTypes:DegreeApplicable pescAcademicSummaryTypes:NonDegreeApplicable pescAcademicSummaryTypes:ConvertedFrom pescAcademicSummaryTypes:ConvertedTo pescAcademicSummaryTypes:UserDefined pescAcademicSummaryTypes:Weighted pescAcademicSummaryTypes:NonWeighted pescAcademicSummaryTypes:Cumulative ) ;
    sh:maxCount 1 ;
    sh:name "Academic Summary Type"@en-US ;
    sh:nodeKind sh:IRI ;
    sh:path pesc:academicSummaryType .

<academicsummaryshapeAdditionalNote> a sh:PropertyShape ;
    sh:class elm:Note ;
    sh:name "Additional Note"@en-US ;
    sh:node <NoteShape> ;
    sh:nodeKind sh:BlankNodeOrIRI ;
    sh:path elm:additionalNote .

<academicsummaryshapeDelinquencies> a sh:PropertyShape ;
    rdfs:comment "It is recommended that probation not be included on the transcript since there is no universally accepted definition of probation, and that other Delinquencies be included at the Session level."@eng ;
    sh:in ( pescDelinquencyCodes:ExclusionAcademic pescDelinquencyCodes:ExclusionDiscipline pescDelinquencyCodes:GoodStanding pescDelinquencyCodes:ProbationGPA pescDelinquencyCodes:ProbationHours pescDelinquencyCodes:SuspensionGPA pescDelinquencyCodes:SuspensionHours pescDelinquencyCodes:ProbationDiscipline pescDelinquencyCodes:SuspensionDiscipline pescDelinquencyCodes:Unknown pescDelinquencyCodes:Other ) ;
    sh:name "Delinquencies"@en-US ;
    sh:nodeKind sh:IRI ;
    sh:path pesc:delinquencies .

<academicsummaryshapeEntryDate> a sh:PropertyShape ;
    rdfs:comment "It would be unusual to find this date on a College Transcript. The date format is ccyy-mm-dd."@eng ;
    sh:datatype xsd:date ;
    sh:maxCount 1 ;
    sh:name "Entry Date"@en-US ;
    sh:nodeKind sh:Literal ;
    sh:path pesc:entryDate .

<academicsummaryshapeExitDate> a sh:PropertyShape ;
    rdfs:comment "This date would typically be the date of graduation for students who did graduate. If the student did not graduate, it would be the last date of known attendance unless the school has a policy on withdrawal from the school. It would be unusual to find this data element on a College Transcript. The date format is ccyy-mm-dd."@eng ;
    sh:datatype xsd:date ;
    sh:maxCount 1 ;
    sh:name "Exit Date"@en-US ;
    sh:nodeKind sh:Literal ;
    sh:path pesc:exitDate .

<academicsummaryshapeGPASummary> a sh:PropertyShape ;
    sh:class pesc:GPA ;
    sh:maxCount 1 ;
    sh:name "GPA Summary"@en-US ;
    sh:node <GPAShape> ;
    sh:nodeKind sh:BlankNode ;
    sh:path pesc:gpaSummary .

<academicsummaryshapeIsSummaryForProgram> a sh:PropertyShape ;
    rdfs:comment "This would not normally be used at this point in the schema, to give detailed data about the academic program in which an award was earned."@eng ;
    sh:class ceds:C200331 ;
    sh:maxCount 1 ;
    sh:name "Is Summary For Program"@en-US ;
    sh:node <AcademicProgramShape> ;
    sh:nodeKind sh:BlankNodeOrIRI ;
    sh:path pesc:isSummaryForProgram .

<academicsummaryshapeSource> a sh:PropertyShape ;
    sh:class ceds:C200239 ;
    sh:maxCount 1 ;
    sh:name "Source"@en-US ;
    sh:node <OrganizationShape> ;
    sh:nodeKind sh:BlankNodeOrIRI ;
    sh:path pesc:source .

<academicsummaryshapeType> a sh:PropertyShape ;
    sh:hasValue pesc:AcademicSummary ;
    sh:minCount 1 ;
    sh:name "Type"@en-US ;
    sh:nodeKind sh:IRI ;
    sh:path rdf:type .

<awardsummaryshapeAcademicHonors> a sh:PropertyShape ;
    sh:class pesc:AcademicHonors ;
    sh:name "Academic Honors"@en-US ;
    sh:node <AcademicHonorsShape> ;
    sh:nodeKind sh:BlankNode ;
    sh:path pesc:academicHonors .

<awardsummaryshapeAcademicSummaryLevel> a sh:PropertyShape ;
    sh:in ( pescCreditLevels:Dual pescCreditLevels:DualGraduate pescCreditLevels:Undergraduate pescCreditLevels:Grade13 pescCreditLevels:Ungraded pescCreditLevels:DualHighSchoolCollege pescCreditLevels:Graduate pescCreditLevels:GraduateProfessional pescCreditLevels:LowerDivision pescCreditLevels:Professional pescCreditLevels:Secondary pescCreditLevels:TechnicalPreparatory pescCreditLevels:UpperDivision pescCreditLevels:Vocational ) ;
    sh:maxCount 1 ;
    sh:name "Academic Summary Level"@en-US ;
    sh:nodeKind sh:IRI ;
    sh:path pesc:academicSummaryLevel .

<awardsummaryshapeAcademicSummaryType> a sh:PropertyShape ;
    sh:in ( pescAcademicSummaryTypes:All pescAcademicSummaryTypes:SenderOnly pescAcademicSummaryTypes:TransferOnly pescAcademicSummaryTypes:AllNotRepeated pescAcademicSummaryTypes:SenderNotRepeated pescAcademicSummaryTypes:TransferNotRepeated pescAcademicSummaryTypes:AcademicRenewal pescAcademicSummaryTypes:CarryoverCredit pescAcademicSummaryTypes:DegreeApplicable pescAcademicSummaryTypes:NonDegreeApplicable pescAcademicSummaryTypes:ConvertedFrom pescAcademicSummaryTypes:ConvertedTo pescAcademicSummaryTypes:UserDefined pescAcademicSummaryTypes:Weighted pescAcademicSummaryTypes:NonWeighted pescAcademicSummaryTypes:Cumulative ) ;
    sh:maxCount 1 ;
    sh:name "Academic Summary Type"@en-US ;
    sh:nodeKind sh:IRI ;
    sh:path pesc:academicSummaryType .

<awardsummaryshapeAdditionalNote> a sh:PropertyShape ;
    sh:class elm:Note ;
    sh:name "Additional Note"@en-US ;
    sh:node <NoteShape> ;
    sh:nodeKind sh:BlankNodeOrIRI ;
    sh:path elm:additionalNote .

<awardsummaryshapeGPASummary> a sh:PropertyShape ;
    sh:class pesc:GPA ;
    sh:maxCount 1 ;
    sh:name "GPA Summary"@en-US ;
    sh:node <GPAShape> ;
    sh:nodeKind sh:BlankNode ;
    sh:path pesc:gpaSummary .

<awardsummaryshapeIsSummaryForAward> a sh:PropertyShape ;
    sh:class ceds:C200335 ;
    sh:maxCount 1 ;
    sh:minCount 1 ;
    sh:name "Is Summary For Award"@en-US ;
    sh:node <AcademicAwardShape> ;
    sh:nodeKind sh:BlankNodeOrIRI ;
    sh:path pesc:isSummaryForAward .

<awardsummaryshapeIsSummaryForProgram> a sh:PropertyShape ;
    rdfs:comment "This would not normally be used at this point in the schema, to give detailed data about the academic program in which an award was earned."@eng ;
    sh:class ceds:C200331 ;
    sh:maxCount 1 ;
    sh:name "Is Summary For Program"@en-US ;
    sh:node <AcademicProgramShape> ;
    sh:nodeKind sh:BlankNodeOrIRI ;
    sh:path pesc:isSummaryForProgram .

<awardsummaryshapeSource> a sh:PropertyShape ;
    sh:class ceds:C200239 ;
    sh:maxCount 1 ;
    sh:name "Source"@en-US ;
    sh:node <OrganizationShape> ;
    sh:nodeKind sh:BlankNodeOrIRI ;
    sh:path pesc:source .

<awardsummaryshapeType> a sh:PropertyShape ;
    sh:hasValue pesc:AwardSummary ;
    sh:minCount 1 ;
    sh:name "Type"@en-US ;
    sh:nodeKind sh:IRI ;
    sh:path rdf:type .

<gpashapeCreditHoursAttempted> a sh:PropertyShape ;
    rdfs:comment "decimal"@eng ;
    sh:datatype xsd:decimal ;
    sh:maxCount 1 ;
    sh:name "Credit Hours Attempted"@en-US ;
    sh:nodeKind sh:Literal ;
    sh:path pesc:creditHoursAttempted .

<gpashapeCreditHoursEarned> a sh:PropertyShape ;
    rdfs:comment "decimal"@eng ;
    sh:datatype xsd:decimal ;
    sh:maxCount 1 ;
    sh:name "Credit Hours Earned"@en-US ;
    sh:nodeKind sh:Literal ;
    sh:path pesc:creditHoursEarned .

<gpashapeCreditHoursGPA> a sh:PropertyShape ;
    rdfs:comment "decimal"@eng ;
    sh:datatype xsd:decimal ;
    sh:maxCount 1 ;
    sh:name "Credit Hours GPA"@en-US ;
    sh:nodeKind sh:Literal ;
    sh:path pesc:creditHoursForGPA .

<gpashapeGPARangeMaximum> a sh:PropertyShape ;
    rdfs:comment "decimal"@eng ;
    sh:datatype xsd:decimal ;
    sh:maxCount 1 ;
    sh:name "GPA Range Maximum"@en-US ;
    sh:nodeKind sh:Literal ;
    sh:path pesc:gpaRangeMaximum .

<gpashapeGPARangeMinimum> a sh:PropertyShape ;
    rdfs:comment "decimal"@eng ;
    sh:datatype xsd:decimal ;
    sh:maxCount 1 ;
    sh:name "GPA Range Minimum"@en-US ;
    sh:nodeKind sh:Literal ;
    sh:path pesc:gpaRangeMinimum .

<gpashapeGradePointAverage> a sh:PropertyShape ;
    rdfs:comment "decimal"@eng ;
    sh:datatype xsd:decimal ;
    sh:maxCount 1 ;
    sh:name "Grade Point Average"@en-US ;
    sh:nodeKind sh:Literal ;
    sh:path pesc:gradePointAverage .

<gpashapeHasCourseCreditUnits> a sh:PropertyShape ;
    sh:in ( ceds:NI000057116219 ceds:NI000057116669 ceds:NI000057116841 ceds:NI000057117114 ceds:NI000057115440 ceds:NI000057115402 ceds:NI000057115492 ceds:NI000057117127 ceds:NI000057116368 ) ;
    sh:maxCount 1 ;
    sh:name "Has Course Credit Units"@en-US ;
    sh:nodeKind sh:IRI ;
    sh:path ceds:P000057 .

<gpashapeTotalQualityPoints> a sh:PropertyShape ;
    rdfs:comment "decimal"@eng ;
    sh:datatype xsd:decimal ;
    sh:maxCount 1 ;
    sh:name "Total Quality Points"@en-US ;
    sh:nodeKind sh:Literal ;
    sh:path pesc:totalQualityPoints .

<gpashapeType> a sh:PropertyShape ;
    sh:hasValue pesc:GPA ;
    sh:minCount 1 ;
    sh:name "Type"@en-US ;
    sh:nodeKind sh:IRI ;
    sh:path rdf:type .

<programsummaryshapeAcademicHonors> a sh:PropertyShape ;
    sh:class pesc:AcademicHonors ;
    sh:name "Academic Honors"@en-US ;
    sh:node <AcademicHonorsShape> ;
    sh:nodeKind sh:BlankNode ;
    sh:path pesc:academicHonors .

<programsummaryshapeAcademicSummaryLevel> a sh:PropertyShape ;
    sh:in ( pescCreditLevels:Dual pescCreditLevels:DualGraduateUndergraduate pescCreditLevels:Grade13 pescCreditLevels:Ungraded pescCreditLevels:DualHighSchoolCollege pescCreditLevels:Graduate pescCreditLevels:GraduateProfessional pescCreditLevels:LowerDivision pescCreditLevels:Professional pescCreditLevels:Secondary pescCreditLevels:TechnicalPreparatory pescCreditLevels:Undergraduate pescCreditLevels:UpperDivision pescCreditLevels:Vocational ) ;
    sh:maxCount 1 ;
    sh:name "Academic Summary Level"@en-US ;
    sh:nodeKind sh:IRI ;
    sh:path pesc:academicSummaryLevel .

<programsummaryshapeAcademicSummaryType> a sh:PropertyShape ;
    rdfs:comment "Since this part of the schema deals only with the academic awards earned, the only recommended value would probably be “DegreeApplicable”."@eng ;
    sh:in ( pescAcademicSummaryTypes:All pescAcademicSummaryTypes:SenderOnly pescAcademicSummaryTypes:TransferOnly pescAcademicSummaryTypes:AllNotRepeated pescAcademicSummaryTypes:SenderNotRepeated pescAcademicSummaryTypes:TransferNotRepeated pescAcademicSummaryTypes:AcademicRenewal pescAcademicSummaryTypes:CarryoverCredit pescAcademicSummaryTypes:DegreeApplicable pescAcademicSummaryTypes:NonDegreeApplicable pescAcademicSummaryTypes:ConvertedFrom pescAcademicSummaryTypes:ConvertedTo pescAcademicSummaryTypes:UserDefined pescAcademicSummaryTypes:Weighted pescAcademicSummaryTypes:NonWeighted pescAcademicSummaryTypes:Cumulative ) ;
    sh:maxCount 1 ;
    sh:name "Academic Summary Type"@en-US ;
    sh:nodeKind sh:IRI ;
    sh:path pesc:academicSummaryType .

<programsummaryshapeAdditionalNote> a sh:PropertyShape ;
    sh:class elm:Note ;
    sh:name "Additional Note"@en-US ;
    sh:node <NoteShape> ;
    sh:nodeKind sh:BlankNodeOrIRI ;
    sh:path elm:additionalNote .

<programsummaryshapeDelinquencies> a sh:PropertyShape ;
    sh:in ( pescDelinquencyCodes:ExclusionAcademic pescDelinquencyCodes:ExclusionDiscipline pescDelinquencyCodes:GoodStanding pescDelinquencyCodes:ProbationGPA pescDelinquencyCodes:ProbationHours pescDelinquencyCodes:SuspensionGPA pescDelinquencyCodes:SuspensionHours pescDelinquencyCodes:ProbationDiscipline pescDelinquencyCodes:SuspensionDiscipline pescDelinquencyCodes:Unknown pescDelinquencyCodes:Other ) ;
    sh:name "Delinquencies"@en-US ;
    sh:nodeKind sh:IRI ;
    sh:path pesc:delinquencies .

<programsummaryshapeExitDate> a sh:PropertyShape ;
    rdfs:comment "The format for the date is ccyy-mm-dd. This would not be the appropriate place in the schema to transmit these data."@eng ;
    sh:datatype xsd:date ;
    sh:maxCount 1 ;
    sh:name "Exit Date"@en-US ;
    sh:nodeKind sh:Literal ;
    sh:path pesc:exitDate .

<programsummaryshapeGPASummary> a sh:PropertyShape ;
    rdfs:comment "Would not typically be included on a College Transcript."@eng ;
    sh:class pesc:GPA ;
    sh:maxCount 1 ;
    sh:name "GPA Summary"@en-US ;
    sh:node <GPAShape> ;
    sh:nodeKind sh:BlankNode ;
    sh:path pesc:gpaSummary .

<programsummaryshapeIsSummaryForProgram> a sh:PropertyShape ;
    sh:class ceds:C200331 ;
    sh:maxCount 1 ;
    sh:minCount 1 ;
    sh:name "Is Summary For Program"@en-US ;
    sh:node <AcademicProgramShape> ;
    sh:nodeKind sh:BlankNodeOrIRI ;
    sh:path pesc:isSummaryForProgram .

<programsummaryshapeSource> a sh:PropertyShape ;
    sh:class ceds:C200239 ;
    sh:maxCount 1 ;
    sh:name "Source"@en-US ;
    sh:node <OrganizationShape> ;
    sh:nodeKind sh:BlankNodeOrIRI ;
    sh:path pesc:source .

<programsummaryshapeType> a sh:PropertyShape ;
    sh:hasValue pesc:ProgramSummary ;
    sh:minCount 1 ;
    sh:name "Type"@en-US ;
    sh:nodeKind sh:IRI ;
    sh:path rdf:type .

<sessionsummaryshapeAcademicHonors> a sh:PropertyShape ;
    sh:class pesc:AcademicHonors ;
    sh:name "Academic Honors"@en-US ;
    sh:node <AcademicHonorsShape> ;
    sh:nodeKind sh:BlankNode ;
    sh:path pesc:academicHonors .

<sessionsummaryshapeAcademicSummaryLevel> a sh:PropertyShape ;
    sh:in ( pescCreditLevels:Dual pescCreditLevels:DualGraduate pescCreditLevels:Undergraduate pescCreditLevels:Grade13 pescCreditLevels:Ungraded pescCreditLevels:DualHighSchoolCollege pescCreditLevels:Graduate pescCreditLevels:GraduateProfessional pescCreditLevels:LowerDivision pescCreditLevels:Professional pescCreditLevels:Secondary pescCreditLevels:TechnicalPreparatory pescCreditLevels:UpperDivision pescCreditLevels:Vocational ) ;
    sh:maxCount 1 ;
    sh:name "Academic Summary Level"@en-US ;
    sh:nodeKind sh:IRI ;
    sh:path pesc:academicSummaryLevel .

<sessionsummaryshapeAcademicSummaryType> a sh:PropertyShape ;
    sh:in ( pescAcademicSummaryTypes:All pescAcademicSummaryTypes:SenderOnly pescAcademicSummaryTypes:TransferOnly pescAcademicSummaryTypes:AllNotRepeated pescAcademicSummaryTypes:SenderNotRepeated pescAcademicSummaryTypes:TransferNotRepeated pescAcademicSummaryTypes:AcademicRenewal pescAcademicSummaryTypes:CarryoverCredit pescAcademicSummaryTypes:DegreeApplicable pescAcademicSummaryTypes:NonDegreeApplicable pescAcademicSummaryTypes:ConvertedFrom pescAcademicSummaryTypes:ConvertedTo pescAcademicSummaryTypes:UserDefined pescAcademicSummaryTypes:Weighted pescAcademicSummaryTypes:NonWeighted pescAcademicSummaryTypes:Cumulative ) ;
    sh:maxCount 1 ;
    sh:name "Academic Summary Type"@en-US ;
    sh:nodeKind sh:IRI ;
    sh:path pesc:academicSummaryType .

<sessionsummaryshapeAdditionalNote> a sh:PropertyShape ;
    sh:class elm:Note ;
    sh:name "Additional Note"@en-US ;
    sh:node <NoteShape> ;
    sh:nodeKind sh:BlankNodeOrIRI ;
    sh:path elm:additionalNote .

<sessionsummaryshapeDelinquencies> a sh:PropertyShape ;
    sh:in ( pescDelinquencyCodes:ExclusionAcademic pescDelinquencyCodes:ExclusionDiscipline pescDelinquencyCodes:GoodStanding pescDelinquencyCodes:ProbationGPA pescDelinquencyCodes:ProbationHours pescDelinquencyCodes:SuspensionGPA pescDelinquencyCodes:SuspensionHours pescDelinquencyCodes:ProbationDiscipline pescDelinquencyCodes:SuspensionDiscipline pescDelinquencyCodes:Unknown pescDelinquencyCodes:Other ) ;
    sh:name "Delinquencies"@en-US ;
    sh:nodeKind sh:IRI ;
    sh:path pesc:delinquencies .

<sessionsummaryshapeEntryDate> a sh:PropertyShape ;
    rdfs:comment "This data element would rarely be seen on a College Transcript."@eng ;
    sh:datatype xsd:date ;
    sh:maxCount 1 ;
    sh:name "Entry Date"@en-US ;
    sh:nodeKind sh:Literal ;
    sh:path pesc:entryDate .

<sessionsummaryshapeExitDate> a sh:PropertyShape ;
    rdfs:comment "This date would typically be the date of graduation for students who did graduate this session. If the student did not graduate, it would be the last date of known enrollment. The date format is ccyy-mm-dd. It would not typically be included on a postsecondary transcript. In rare cases, it might be included for the final session the student attended at that school."@eng ;
    sh:datatype xsd:date ;
    sh:maxCount 1 ;
    sh:name "Exit Date"@en-US ;
    sh:nodeKind sh:Literal ;
    sh:path pesc:exitDate .

<sessionsummaryshapeGPASummary> a sh:PropertyShape ;
    rdfs:comment "This would typically be where items like Dean’s List at the end of a session are listed."@eng ;
    sh:class pesc:GPA ;
    sh:maxCount 1 ;
    sh:name "GPA Summary"@en-US ;
    sh:node <GPAShape> ;
    sh:nodeKind sh:BlankNode ;
    sh:path pesc:gpaSummary .

<sessionsummaryshapeIsSummaryForProgram> a sh:PropertyShape ;
    rdfs:comment "It would be quite unusual to see this included on a college transcript at this point in the schema."@eng ;
    sh:class ceds:C200331 ;
    sh:maxCount 1 ;
    sh:name "Is Summary For Program"@en-US ;
    sh:node <AcademicProgramShape> ;
    sh:nodeKind sh:BlankNodeOrIRI ;
    sh:path pesc:isSummaryForProgram .

<sessionsummaryshapeIsSummaryForSession> a sh:PropertyShape ;
    sh:class ceds:C200245 ;
    sh:maxCount 1 ;
    sh:minCount 1 ;
    sh:name "Is Summary For Session"@en-US ;
    sh:node <AcademicSessionShape> ;
    sh:nodeKind sh:BlankNodeOrIRI ;
    sh:path pesc:isSummaryForSession .

<sessionsummaryshapeSource> a sh:PropertyShape ;
    sh:class ceds:C200239 ;
    sh:maxCount 1 ;
    sh:name "Source"@en-US ;
    sh:node <OrganizationShape> ;
    sh:nodeKind sh:BlankNodeOrIRI ;
    sh:path pesc:source .

<sessionsummaryshapeType> a sh:PropertyShape ;
    sh:hasValue pesc:SessionSummary ;
    sh:minCount 1 ;
    sh:name "Type"@en-US ;
    sh:nodeKind sh:IRI ;
    sh:path rdf:type .

<studentshapeHasSummary> a sh:PropertyShape ;
    sh:minCount 1 ;
    sh:name "Has Summary"@en-US ;
    sh:nodeKind sh:BlankNodeOrIRI ;
    sh:or ( [ sh:class pesc:AcademicSummary ] [ sh:class pesc:AwardSummary ] [ sh:class pesc:ProgramSummary ] [ sh:class pesc:SessionSummary ] ) ;
    sh:path pesc:hasSummary ;
    sh:severity sh:Warning .

<AcademicHonorsShape> a sh:NodeShape ;
    rdfs:label "Academic Honors"@en ;
    sh:closed false ;
    sh:property <academichonorsshapeHonorsLevel>,
        <academichonorsshapeHonorsTitle>,
        <academichonorsshapeType> ;
    sh:targetClass pesc:AcademicHonors .

<AcademicProgramShape> a sh:NodeShape ;
    rdfs:label "Academic Program"@en ;
    sh:closed false ;
    sh:targetClass ceds:C200331 .

<GPAShape> a sh:NodeShape ;
    rdfs:label "GPA"@en ;
    sh:closed false ;
    sh:property <gpashapeCreditHoursAttempted>,
        <gpashapeCreditHoursEarned>,
        <gpashapeCreditHoursGPA>,
        <gpashapeGPARangeMaximum>,
        <gpashapeGPARangeMinimum>,
        <gpashapeGradePointAverage>,
        <gpashapeHasCourseCreditUnits>,
        <gpashapeTotalQualityPoints>,
        <gpashapeType> ;
    sh:targetClass pesc:GPA .

<NoteShape> a sh:NodeShape ;
    rdfs:label "Note"@en ;
    sh:closed false ;
    sh:targetClass elm:Note .

<OrganizationShape> a sh:NodeShape ;
    rdfs:label "Organization"@en ;
    sh:closed false ;
    sh:targetClass ceds:C200239 .

